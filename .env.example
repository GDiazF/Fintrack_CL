DEBUG=True
SECRET_KEY=django-insecure-cambiame-por-algo-seguro-en-produccion
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3
# URL que se inyecta en el código GAS del perfil (usar HTTPS en producción)
PUBLIC_BASE_URL=http://127.0.0.1:8080

# Producción (ejemplo en la VM):
# DEBUG=False
# SECRET_KEY=genera-una-clave-larga-aleatoria
# ALLOWED_HOSTS=146.181.41.108,tudominio.com
# CSRF_TRUSTED_ORIGINS=http://146.181.41.108
# PUBLIC_BASE_URL=http://146.181.41.108
# BEHIND_PROXY=True

# --- Email (opcional en local: sin EMAIL_HOST los mails salen por consola) ---
# Gmail: activa 2FA → crea "Contraseña de aplicaciones" y pégala en EMAIL_HOST_PASSWORD
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=tu-correo@gmail.com
# EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx
# DEFAULT_FROM_EMAIL=Fintrack CL <tu-correo@gmail.com>
